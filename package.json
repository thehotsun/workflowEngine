{
  "name": "workflow-engine",
  "version": "1.0.0",
  "description": "可插拔 AI 工作流引擎",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "ingest": "node rag/ingest.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop workflow-engine",
    "pm2:restart": "pm2 restart workflow-engine",
    "pm2:reload": "pm2 reload workflow-engine",
    "pm2:logs": "pm2 logs workflow-engine",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.4",
    "fastify": "^4.26.0",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "sqlite-vec": "^0.1.9",
    "uuid": "^9.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite-vec"
    ]
  }
}